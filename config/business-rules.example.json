      "category": "GroupPolicyBaseline",
      "businessQuestion": "Politicas que controlam DCs podem ser alteradas por principals nao aprovados?",
      "severityBase": "Critical",
      "decision": "Adjust",
      "thresholdValue": 0,
      "benchmarkRefs": [
        "Microsoft Group Policy scope and processing",
